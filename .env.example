# ---- Postgres ----
POSTGRES_USER=oddzilla
POSTGRES_PASSWORD=oddzilla
POSTGRES_DB=oddzilla
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- RabbitMQ ----
RABBITMQ_USER=oddzilla
RABBITMQ_PASSWORD=oddzilla
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---- API ----
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://oddzilla:oddzilla@localhost:5432/oddzilla?schema=public
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://oddzilla:oddzilla@localhost:5672

# 32+ chars each, generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_me_with_a_32_byte_hex_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace_me_with_a_different_32_byte_hex_string_xxxxxxxxxxxxxxxxxxx

# Seeded on first `pnpm db:seed`. mustChangePassword is forced true.
ADMIN_EMAIL=admin@oddzilla.local
ADMIN_PASSWORD=ChangeMeOnFirstLogin123!

# ---- Web ----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---- Oddin feed ----
ODDIN_API_TOKEN=
ODDIN_ENVIRONMENT=integration
ODDIN_NODE_ID=1
ODDIN_AMQP_URL=
ODDIN_EXCHANGE=unifiedfeed.integration
ODDIN_QUEUE_NAME=oddzilla.consumer
ODDIN_ROUTING_KEY_PATTERN=#

# ---- Mock feed (dev only) ----
ENABLE_MOCK_FEED=true
MOCK_FEED_TICK_MS=2000
MOCK_FEED_SEED=42
