{
  "name": "oddzilla",
  "version": "0.1.0",
  "private": true,
  "description": "Oddzilla esports sportsbook monorepo",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm build:packages && pnpm -r --parallel --filter=\"@oddzilla/api\" --filter=\"@oddzilla/web\" --filter=\"@oddzilla/shared\" --filter=\"@oddzilla/db\" run dev",
    "build:packages": "pnpm -F @oddzilla/shared build && pnpm -F @oddzilla/db prisma:generate && pnpm -F @oddzilla/db build",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "infra:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "infra:logs": "docker compose --env-file .env -f infra/docker-compose.yml logs -f",
    "db:generate": "pnpm -F @oddzilla/db prisma:generate",
    "db:migrate": "pnpm -F @oddzilla/db prisma:migrate",
    "db:seed": "pnpm -F @oddzilla/db seed",
    "db:studio": "pnpm -F @oddzilla/db prisma:studio",
    "test": "pnpm -r run test",
    "e2e": "pnpm -F @oddzilla/e2e playwright test"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
